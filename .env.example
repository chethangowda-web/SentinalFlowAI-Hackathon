# =============================================================================
# SentinelFlow - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# NODE
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-strong-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_SECRET=change-this-to-another-strong-random-string-at-least-32-chars

# ---------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@aws-0-region.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=2000

# ---------------------------------------------------------------------------
# AI PROVIDERS
# ---------------------------------------------------------------------------

# Groq - primary LLM provider (llama-3.1-8b)
GROQ_API_KEY=gsk_your-groq-api-key

# HuggingFace - embedding model provider (BAAI/bge-large-en-v1.5, 1024 dims)
HUGGINGFACE_API_KEY=hf_your-huggingface-api-key
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ---------------------------------------------------------------------------
# QDRANT VECTOR DATABASE (Cloud)
# ---------------------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.us-central1-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=sentinelflow-incidents

# ---------------------------------------------------------------------------
# ENKRYPT AI GOVERNANCE
# ---------------------------------------------------------------------------
ENKRYPTAI_API_KEY=sk-your-enkryptai-api-key
ENKRYPTAI_BASE_URL=https://api.enkryptai.com
ENKRYPTAI_GUARDRAIL_NAME=sentinelflow-guardrail
ENKRYPTAI_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# WEBSOCKET
# ---------------------------------------------------------------------------
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000
WS_MAX_PAYLOAD=1048576
WS_RATE_LIMIT=100

# ---------------------------------------------------------------------------
# OBSERVABILITY (Optional - Prometheus, Grafana, Loki, Jaeger)
# ---------------------------------------------------------------------------
# PROMETHEUS_URL=http://prometheus:9090
# GRAFANA_URL=http://grafana:3000
# GRAFANA_API_KEY=your-grafana-api-key
# LOKI_URL=http://loki:3100
# JAEGER_URL=http://jaeger:16686

# ---------------------------------------------------------------------------
# NOTIFICATIONS (Optional - SMTP / Slack / Teams / Discord)
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=sentinelflow@example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# TEAMS_WEBHOOK_URL=https://your-team.webhook.office.com/xxx
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# WEBHOOK_URL=https://hooks.example.com/sentinelflow
NOTIFICATION_RETRY_LIMIT=3
NOTIFICATION_QUEUE_SIZE=1000
NOTIFICATION_TIMEOUT=5000

# ---------------------------------------------------------------------------
# KUBERNETES (Optional - for K8s Operations Agent)
# ---------------------------------------------------------------------------
# KUBERNETES_CONFIG_PATH=/path/to/kubeconfig

# ---------------------------------------------------------------------------
# BRUTE FORCE PROTECTION
# ---------------------------------------------------------------------------
BRUTE_FORCE_MAX_ATTEMPTS=5

# ---------------------------------------------------------------------------
# FRONTEND (Vite) - Used during build only
# ---------------------------------------------------------------------------
VITE_API_URL=https://api.sentinelflow.io
VITE_WS_URL=wss://api.sentinelflow.io
VITE_ENV=production
VITE_BUILD_VERSION=0.1.0

# ---------------------------------------------------------------------------
# DEMO / SEEDING
# ---------------------------------------------------------------------------
# Set to 'true' to skip automatic demo data seeding on fresh database
# SKIP_DEMO_AUTO_START=true
